{
  "name": "nahida-agent",
  "version": "3.0.0",
  "description": "纳西妲 AI Agent — 基于 Electron + Ollama 的桌面端 AI 助手，支持 Live2D、视觉感知、群聊和 TTS 语音",
  "author": "Kuest10n",
  "private": true,
  "main": "dist/main/main/index.js",
  "keywords": [
    "nahida-agent",
    "genshin-impact",
    "electron",
    "ollama",
    "gpt-sovits",
    "live2d",
    "ai-assistant"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite -c vite.renderer.config.ts",
    "dev:electron": "npm run build:preload && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://localhost:5173/ nodemon --watch dist/main --watch dist/preload --exec \"electron .\"",
    "build:renderer": "vite build -c vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:preload && npm run build:main && npm run build:renderer",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json",
    "pack": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --publish=never"
  },
  "devDependencies": {
    "@types/imap": "^0.8.43",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "imap": "^0.8.19",
    "keytar": "^7.9.0",
    "nodemailer": "^9.0.3",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.4.3",
    "pngjs": "^7.0.0",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.0",
    "systeminformation": "^5.31.16",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.0"
  }
}
