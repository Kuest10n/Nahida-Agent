{
  "name": "nahida-agent",
  "version": "0.9.4",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite -c vite.renderer.config.ts",
    "dev:electron": "npm run build:preload && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://localhost:5173/ nodemon --watch dist/main --watch dist/preload --exec \"electron .\"",
    "build:renderer": "vite build -c vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:preload && npm run build:main && npm run build:renderer",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "node-llama-cpp": "^3.19.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.4.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "systeminformation": "^5.31.16",
    "zod": "^3.23.0"
  }
}
