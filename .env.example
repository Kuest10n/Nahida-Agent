# ── Ollama 配置 ────────────────────────────────────────────────

# ollama 服务地址（默认 localhost）
# NAHIDA_OLLAMA_HOST=localhost

# ollama 服务端口（默认 11434）
# NAHIDA_OLLAMA_PORT=11434

# 请求超时（毫秒，默认 30000）
# NAHIDA_OLLAMA_TIMEOUT=30000

# ── 模型配置 ──────────────────────────────────────────────────

# 本地模型名（用于日常对话，默认 qwen3-8b-nahida）
# NAHIDA_MODEL_LOCAL=qwen3-8b-nahida

# 标准模型名（云端，用于深度思考，默认 deepseek-v4pro）
# NAHIDA_MODEL_STANDARD=deepseek-v4pro

# 快速模型名（云端，用于快速响应，默认 deepseek-v4pro-flash）
# NAHIDA_MODEL_FLASH=deepseek-v4pro-flash

# 审查模型名（用于四审层，默认 qwen2.5-1.5b-nahida）
# NAHIDA_MODEL_REVIEW=qwen2.5-1.5b-nahida

# ── API Key（可选，云端模型需要） ──────────────────────────────

# DeepSeek API Key（不填则只使用本地模型）
# NAHIDA_API_DEEPSEEK_KEY=your_deepseek_api_key_here

# ── 本地 LLM 配置（已废弃，使用 Ollama） ───────────────────
# 旧版本使用 node-llama-cpp 直接加载 GGUF，现统一使用 Ollama
# 请通过 NAHIDA_MODEL_LOCAL 指定本地 Ollama 模型名

# ── 视觉感知配置（v3.0 新增） ──────────────────────────────

# Vision 模型名（用于图像理解，如 qwen2-vl，默认与主模型相同）
# NAHIDA_MODEL_VISION=qwen2-vl:7b-instruct

# OCR 语言（默认 chi_sim+eng，即简体中文+英文）
# NAHIDA_OCR_LANG=chi_sim+eng

# 屏幕监控默认间隔（毫秒，默认 2000）
# NAHIDA_MONITOR_INTERVAL=2000

# 屏幕监控默认帧差阈值（%，默认 5）
# NAHIDA_MONITOR_THRESHOLD=5

# Vision 缓存最大条数（默认 50）
# NAHIDA_VISION_CACHE_SIZE=50

# Vision 缓存 TTL（秒，默认 300）
# NAHIDA_VISION_CACHE_TTL=300

# ── Python 环境配置（v0.9.4 新增） ──────────────────────────────

# Python 解释器路径（留空则自动检测：嵌入式 Python → 系统 Python）
# NAHIDA_PYTHON_PATH=

# ── 会话配置 ──────────────────────────────────────────────────

# 最大历史轮数（默认 10）
# NAHIDA_SESSION_MAX_HISTORY=10

# 会话过期时间（分钟，默认 30）
# NAHIDA_SESSION_TTL=30

# 最大保留会话数（默认 50）
# NAHIDA_SESSION_MAX_COUNT=50

# ── TTS / GPT-SoVITS / RVC 语音配置 ──────────────────────────────────

# TTS 适配器类型：edge-tts（CPU 默认）或 gpt-sovits（GPU，日常对话主力）
# NAHIDA_VOICE_ADAPTER=edge-tts

# edge-tts 语音名（默认 zh-CN-XiaoyiNeural 晓伊）
# NAHIDA_VOICE_EDGE_VOICE=zh-CN-XiaoyiNeural

# GPT-SoVITS API 地址（默认 http://localhost:9880，启用 GPT-SoVITS 时需先启动 api_v2.py）
# NAHIDA_GPTSOVITS_API_URL=http://localhost:9880

# GPT-SoVITS 参考音频根目录（如 F:\nahida\v4\纳西妲_ZH\reference_audios\中文\emotions）
# NAHIDA_GPTSOVITS_REF_DIR=

# GPT-SoVITS 模型目录（含 .ckpt + .pth，如 F:\nahida\v4\纳西妲_ZH）
# NAHIDA_GPTSOVITS_MODEL_DIR=

# ── RVC 配置（AI 翻唱独立模块）──────────────────────────────────

# RVC 模型文件名（项目 assets/rvc/ 下，默认 nahida_v0.3_100e.pth）
# NAHIDA_VOICE_RVC_MODEL=nahida_v0.3_100e.pth

# RVC 模型版本标识（默认 V0.3）
# NAHIDA_VOICE_RVC_VERSION=V0.3

# RVC WebUI 根目录（启用 AI 翻唱时必须配置，如 F:\RVC20240604Nvidia）
# NAHIDA_VOICE_RVC_ROOT=
